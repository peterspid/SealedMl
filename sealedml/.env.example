# SealedML Environment Variables Template
# Copy this to .env (for contracts) or .env.local (for frontend)

# ============================================
# CONTRACTS (.env) - Private, server-side only
# ============================================

# Wallet Private Key (REQUIRED for deployment)
# Get testnet ETH from: https://www.alchemy.com/faucets/ethereum-sepolia
PRIVATE_KEY=your_private_key_here

# RPC URLs (Public endpoints)
SEPOLIA_RPC_URL=https://ethereum-sepolia.publicnode.com
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
BASE_SEPOLIA_RPC_URL=https://base-sepolia.publicnode.com

# Optional: Etherscan API Key (for contract verification)
# Get from: https://etherscan.io/apis
ETHERSCAN_API_KEY=

# Optional: CoinMarketCap API (for gas reporting)
# Get from: https://coinmarketcap.com/api
COINMARKETCAP_API_KEY=


# ============================================
# FRONTEND (.env.local) - Public, exposed to frontend
# ============================================

# Contract Addresses (after deployment)
NEXT_PUBLIC_MODEL_REGISTRY_ETH=0x...
NEXT_PUBLIC_SEALED_ML_ETH=0x...
NEXT_PUBLIC_RESULT_MANAGER_ETH=0x...
NEXT_PUBLIC_ACCESS_CONTROL_ETH=0x...

# WalletConnect Project ID (optional)
# Get from: https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ============================================
# HOW TO GET API KEYS
# ============================================

# 1. Testnet ETH:
#    - Ethereum Sepolia: https://www.alchemy.com/faucets/ethereum-sepolia
#    - Arbitrum Sepolia: https://www.alchemy.com/faucets/arbitrum-sepolia
#    - Base Sepolia: https://www.alchemy.com/faucets/base-sepolia

# 2. WalletConnect Project ID:
#    - Go to https://cloud.walletconnect.com
#    - Create new project
#    - Copy Project ID

# 3. Etherscan API (optional):
#    - Go to https://etherscan.io/apis
#    - Get free API key
